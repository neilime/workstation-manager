{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  onboarding: true,
  platform: "github",
  platformCommit: "enabled",
  prConcurrentLimit: 0,
  prHourlyLimit: 20,
  semanticCommits: "enabled",
  enabledManagers: ["ansible", "ansible-galaxy", "custom.regex"],
  customManagers: [
    {
      customType: "regex",
      description: "Update pinned PHP defaults in Ansible config",
      managerFilePatterns: [
        "/^ansible\\/(group_vars\\/all|vars\\/private\\.override\\.example)\\.yml$/",
      ],
      matchStrings: ['(?<indent>\\s+)php:\\s+"(?<currentValue>[^"]+)"'],
      depNameTemplate: "php/php-src",
      datasourceTemplate: "github-tags",
      extractVersionTemplate: "^php-(?<version>.+)$",
      versioningTemplate: "semver",
      autoReplaceStringTemplate: '{{{indent}}}php: "{{{newValue}}}"',
    },
    {
      customType: "regex",
      description: "Update pinned Chezmoi defaults across config and tests",
      managerFilePatterns: [
        "/^ansible\\/group_vars\\/all\\.yml$/",
        "/^ansible\\/collections\\/ansible_collections\\/neilime\\/workstation_setup\\/plugins\\/module_utils\\/desired_state_support\\.py$/",
        "/^ansible\\/collections\\/ansible_collections\\/neilime\\/workstation_setup\\/tests\\/unit\\/plugins\\/module_utils\\/test_desired_state\\.py$/",
      ],
      matchStringsStrategy: "any",
      matchStrings: [
        'chezmoi:\\n(?:[^\\n]*\\n){0,6}?\\s+version:\\s+"(?<currentValue>[^"]+)"',
        '"source": "neilime/workstation-config",\\n\\s+"version": "(?<currentValue>[^"]+)",',
        '\\("version", "(?<currentValue>[^"]+)"\\),',
      ],
      depNameTemplate: "twpayne/chezmoi",
      datasourceTemplate: "github-releases",
      extractVersionTemplate: "^v?(?<version>.+)$",
      versioningTemplate: "semver",
    },
    {
      customType: "regex",
      description: "Update the major-only Helm track in mise defaults",
      managerFilePatterns: ["/^ansible\\/group_vars\\/all\\.yml$/"],
      matchStrings: [
        '(?<indent>\\s+)"aqua:helm/helm": "(?<currentValue>\\d+)"',
      ],
      depNameTemplate: "helm/helm",
      datasourceTemplate: "github-releases",
      versioningTemplate: "semver",
      currentValueTemplate: "{{{currentValue}}}.0.0",
      autoReplaceStringTemplate: '{{{indent}}}"aqua:helm/helm": "{{{newMajor}}}"',
    },
  ],
  packageRules: [],
}
